{
  "$schema": "https://json-schema.org/draft-06/schema#",
  "title": "Generator Input",
  "type": "object",
  "required": [
    "count",
    "players",
    "courtCount",
    "teamSize"
  ],
  "properties": {
    "count": {
      "type": "integer"
    },
    "players": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "courtCount": {
      "type": "integer"
    },
    "teamSize": {
      "type": "integer"
    }
  }
}
